# MiniRouter runtime configuration
# Copy to .env and replace every `replace-me` value before starting.

# Local development only. In production set this to false and configure
# MINIROUTER_BOOTSTRAP_ADMIN_EMAIL for a one-time initial administrator.
MINIROUTER_SOLO=true
MINIROUTER_PORT=8402

# Used only for cost accounting when model prices are stored in CNY.
MINIROUTER_CNY_PER_USD=7.2

# Set this only for the first production start with MINIROUTER_SOLO=false.
# The generated API key is written once to the service log; remove this value
# after saving the key.
# MINIROUTER_BOOTSTRAP_ADMIN_EMAIL=admin@example.com

# Configure the required slots. The provider can be omitted for auto-detection
# or set to `openai-compatible` / `anthropic`.
MINIROUTER_BALANCED_PROVIDER=openai-compatible
MINIROUTER_BALANCED_BASE_URL=https://api.example.com/v1
MINIROUTER_BALANCED_API_KEY=replace-me
MINIROUTER_BALANCED_MODEL=replace-me
MINIROUTER_BALANCED_SUPPORTS_TOOLS=true
MINIROUTER_BALANCED_SUPPORTS_VISION=false
MINIROUTER_BALANCED_CONTEXT_WINDOW=128000

MINIROUTER_STRONG_PROVIDER=openai-compatible
MINIROUTER_STRONG_BASE_URL=https://api.example.com/v1
MINIROUTER_STRONG_API_KEY=replace-me
MINIROUTER_STRONG_MODEL=replace-me
MINIROUTER_STRONG_SUPPORTS_TOOLS=true
MINIROUTER_STRONG_SUPPORTS_VISION=false
MINIROUTER_STRONG_CONTEXT_WINDOW=128000

# Vision requests require this slot. Set it to an image-capable endpoint.
MINIROUTER_VISION_PROVIDER=openai-compatible
MINIROUTER_VISION_BASE_URL=https://api.example.com/v1
MINIROUTER_VISION_API_KEY=replace-me
MINIROUTER_VISION_MODEL=replace-me
MINIROUTER_VISION_SUPPORTS_TOOLS=false
MINIROUTER_VISION_SUPPORTS_VISION=true
MINIROUTER_VISION_CONTEXT_WINDOW=32768

# Optional fast slot. When omitted, simple requests fall back to BALANCED.
# MINIROUTER_FAST_PROVIDER=openai-compatible
# MINIROUTER_FAST_BASE_URL=https://api.example.com/v1
# MINIROUTER_FAST_API_KEY=replace-me
# MINIROUTER_FAST_MODEL=replace-me
